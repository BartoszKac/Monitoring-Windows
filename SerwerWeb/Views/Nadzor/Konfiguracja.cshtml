@model List<string>

<div class="container mt-4">
    <h2>Eksplorator Folderów - Wybór Monitoringu</h2>
    <p>Obecna lokalizacja: <strong>@ViewBag.ObecnaSciezka</strong></p>

    <div class="list-group">
        @if (ViewBag.Rodzic != null)
        {
            <a href="@Url.Action("Konfiguracja", new { sciezka = ViewBag.Rodzic })" class="list-group-item list-group-item-secondary">
                ⬅️ W górę (Rodzic)
            </a>
        }

        @foreach (var folder in Model)
        {
            <div class="list-group-item d-flex justify-content-between align-items-center">
                <a href="@Url.Action("Konfiguracja", new { sciezka = folder })" style="text-decoration: none; color: #333; flex-grow: 1;">
                    📁 @System.IO.Path.GetFileName(folder)
                </a>

                <form asp-action="ZatwierdzFolder" method="post" class="m-0">
                    <input type="hidden" name="sciezka" value="@folder" />
                    <button type="submit" class="btn btn-sm btn-success">Śledź ten folder</button>
                </form>
            </div>
        }
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Index")" class="btn btn-primary">Wróć do Historii Zdarzeń</a>
    </div>
</div>