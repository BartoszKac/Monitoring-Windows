@model webserwer.Models.ZdarzeniePliku

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h2>Podgląd pliku: @Model.NazwaPliku</h2>
        <a href="@Url.Action("Index")" class="btn btn-secondary">Powrót do listy</a>
    </div>

    <div class="card mt-3">
        <div class="card-header bg-dark text-white">
            <strong>Student:</strong> @Model.NazwaStudenta |
            <strong>Data:</strong> @Model.DataLogowania.ToString("dd.MM.yyyy HH:mm:ss") |
            <strong>Status:</strong> @(Model.CzyToKopia ? "KOPIA/PLAGIAT" : "OK")
        </div>
        <div class="card-body bg-light">
            <pre style="background-color: #f8f9fa; padding: 15px; border: 1px solid #ddd; border-radius: 5px; overflow-x: auto;"><code>@Model.Tresc</code></pre>
        </div>
    </div>
</div>