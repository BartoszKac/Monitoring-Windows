@* PLIK: Views/Nadzor/Index.cshtml *@
@model List<webserwer.Models.ZdarzeniePliku>
@using webserwer.Models

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>🚀 Panel Nadzoru</h2>
        <div class="d-flex gap-2 flex-wrap">
            <a href="@Url.Action("OstatnieAktywnosci")" class="btn btn-warning btn-sm fw-bold text-dark">🌐 Logi globalne</a>
            <a href="@Url.Action("CzarnaListaView")" class="btn btn-danger btn-sm fw-bold">🚫 Czarna lista</a>
        </div>
    </div>

    @{
        var komputery = ViewBag.Komputery as List<Komputer> ?? new();
        var wybranyKomp = ViewBag.WybranyKomputer as string ?? "";
    }

    <div class="card mb-3 shadow-sm">
        <div class="card-header p-0 bg-dark">
            <ul class="nav nav-tabs border-0" style="flex-wrap: nowrap; overflow-x: auto;">
                <li class="nav-item">
                    <a class="nav-link @(string.IsNullOrEmpty(wybranyKomp) ? "active bg-white text-dark" : "text-white")"
                       href="@Url.Action("Index")">🌐 Wszystkie</a>
                </li>
                @foreach (var k in komputery)
                {
                    bool aktywny = wybranyKomp == k.NazwaKomputera;
                    <li class="nav-item">
                        <a class="nav-link @(aktywny ? "active bg-white text-dark" : "text-white")"
                               href="@Url.Action("Index", new { komputer = k.NazwaKomputera })">
                            <span class="me-1">@(k.Online ? "🟢" : "⚫")</span>
                            @k.NazwaKomputera
                            <small class="text-secondary ms-1">@k.NazwaStudenta</small>
                        </a>
                    </li>
                }
            </ul>
        </div>

        <div class="card-body py-2">
            @if (!string.IsNullOrEmpty(wybranyKomp))
            {
                var komp = komputery.FirstOrDefault(k => k.NazwaKomputera == wybranyKomp);
                if (komp != null)
                {
                    <div class="d-flex align-items-center gap-3 flex-wrap">
                        @if (komp.Online)
                        {
                            <span class="badge bg-success">● Online</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">● Offline – @komp.OstatnioWidziany.ToString("HH:mm dd.MM")</span>
                        }
                        <span class="text-muted small">Student: <strong>@komp.NazwaStudenta</strong></span>
                        <span class="text-muted small">Śledzone foldery: <strong>@komp.Foldery.Count</strong></span>
                        <a href="@Url.Action("KomputerFoldery", new { id = komp.Id })" class="btn btn-sm btn-outline-primary">
                            ⚙ Zarządzaj folderami
                        </a>
                    </div>
                }
            }
            else
            {
                <div class="row g-2">
                    @foreach (var k in komputery)
                    {
                        <div class="col-auto">
                            <div class="border rounded px-3 py-2 d-flex align-items-center gap-2 bg-light">
                                <span>@(k.Online ? "🟢" : "⚫")</span>
                                <div>
                                    <strong>@k.NazwaKomputera</strong>
                                    <small class="text-muted d-block">@k.NazwaStudenta</small>
                                </div>
                                <a href="@Url.Action("KomputerFoldery", new { id = k.Id })"
                                   class="btn btn-sm btn-outline-secondary ms-2" title="Zarządzaj folderami">⚙</a>
                            </div>
                        </div>
                    }
                    @if (!komputery.Any())
                    {
                        <div class="col"><em class="text-muted">Żaden agent się jeszcze nie połączył.</em></div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h5>
            Historia aktywności
            @if (!string.IsNullOrEmpty(wybranyKomp))
            {
                <span class="badge bg-primary ms-1">@wybranyKomp</span>
            }
        </h5>
        <small class="text-muted">Ostatnie 200 rekordów</small>
    </div>

    <div class="table-responsive shadow-sm">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Komputer</th>
                    <th>Student</th>
                    <th>Plik</th>
                    <th>Data</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var z in Model)
                {
                    <tr class="@(z.CzyToKopia ? "table-danger" : "")">
                        <td>
                            <a href="@Url.Action("Index", new { komputer = z.NazwaKomputera })"
                               class="badge bg-dark text-decoration-none">🖥 @z.NazwaKomputera</a>
                        </td>
                        <td><strong>@z.NazwaStudenta</strong></td>
                        <td>
                            <a href="@Url.Action("Szczegoly", new { id = z.Id })" class="text-decoration-none fw-bold">
                                📄 @z.NazwaPliku
                            </a>
                            @if (z.CzyToKopia)
                            {
                                <br />
                            
                                <small class="text-danger">⚠ Duplikat!</small>
                            }
                        </td>
                        <td class="small text-muted">
                            @z.DataLogowania.ToString("dd.MM.yyyy")
                            <span class="badge bg-light text-dark border">@z.DataLogowania.ToString("HH:mm")</span>
                        </td>
                        <td>
                            @if (z.CzyToKopia)
                            {
                                <span class="badge bg-danger">KOPIA</span>
                            }
                            else
                            {
                                <span class="badge bg-success">OK</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center p-5 text-muted"><em>Brak danych.</em></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        const hub = new signalR.HubConnectionBuilder()
            .withUrl("/nadzorHub")
            .withAutomaticReconnect()
            .build();

        hub.on("AgentPolaczony", () => location.reload());
        hub.on("AgentRozlaczony", () => location.reload());

        hub.start().then(() => hub.invoke("DolaczDoGrupyAdmin")).catch(console.error);
    </script>
}
